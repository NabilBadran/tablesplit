# ── Supabase ──────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com, then copy these from
# Project Settings → API. The anon key is safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── Staff dashboard ───────────────────────────────────────────────────────
# Shared password that unlocks /staff. Change it before any real demo.
NEXT_PUBLIC_STAFF_PASSWORD=lumo2025

# ── EmailJS (digital receipts) ────────────────────────────────────────────
# Free at https://emailjs.com. Connect an email service, create a template,
# then copy these three from the dashboard. All three are safe in the browser.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
